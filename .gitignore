# Project folders (generally safe but keep template tracked)
projects/*
!projects/.template/

# Archive (may contain customer data)
archive/*

# Next.js
web/.next/
web/node_modules/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

